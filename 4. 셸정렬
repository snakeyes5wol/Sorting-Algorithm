def shell_sort(arr):
    n = len(arr)
    # 초기 간격(gap)은 배열 길이의 절반으로 설정
    gap = n // 2
    step = 1
    
    # 간격이 0보다 큰 동안 반복 (최종적으로 gap이 1이 될 때까지)
    while gap > 0:
        # 간격(gap)만큼 떨어진 요소들을 대상으로 삽입 정렬 수행
        for i in range(gap, n):
            temp = arr[i]
            j = i
            
            # j가 gap보다 크거나 같고, 
            # (j - gap) 위치의 요소가 temp보다 크면 뒤로 밀어냄
            while j >= gap and arr[j - gap] > temp:
                arr[j] = arr[j - gap]
                j -= gap
                
            # 찾은 위치에 temp 삽입
            arr[j] = temp
            
        # 각 간격(gap)별 정렬이 끝날 때마다 진행 상황 출력
        print(f"{step}단계 진행 (현재 간격 gap={gap}): {arr}")
        
        # 간격을 절반으로 줄임
        gap //= 2
        step += 1
        
    return arr

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 셸 정렬 실행
        sorted_data = shell_sort(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
