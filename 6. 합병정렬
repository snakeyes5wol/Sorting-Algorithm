def merge_sort_run(arr):
    step = [1] # 단계 횟수를 기록하기 위한 리스트
    
    def merge_sort(temp_arr):
        # 배열의 길이가 1 이하면 이미 정렬된 것으로 보고 그대로 반환
        if len(temp_arr) <= 1:
            return temp_arr
        
        # 1. 분할(Divide): 배열의 중간 지점을 찾아 좌우로 나눔
        mid = len(temp_arr) // 2
        left = merge_sort(temp_arr[:mid])
        right = merge_sort(temp_arr[mid:])
        
        # 2. 병합(Merge): 나누어진 두 배열을 크기순으로 비교하며 합침
        merged = []
        i = j = 0
        
        # 양쪽 배열에 요소가 남아있는 동안 비교하여 작은 값을 먼저 넣음
        while i < len(left) and j < len(right):
            if left[i] < right[j]:
                merged.append(left[i])
                i += 1
            else:
                merged.append(right[j])
                j += 1
                
        # 한쪽 배열이 먼저 끝난 경우, 남은 요소들을 그대로 뒤에 이어 붙임
        merged.extend(left[i:])
        merged.extend(right[j:])
        
        # 각 단계별 진행 상황 출력 (어떤 배열들이 합쳐졌는지 확인)
        print(f"{step[0]}단계 병합 완료: {merged} (병합 전: {left} + {right})")
        step[0] += 1
        
        return merged

    # 전체 배열을 대상으로 병합 정렬 시작
    return merge_sort(arr)

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 병합 정렬 실행
        sorted_data = merge_sort_run(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
