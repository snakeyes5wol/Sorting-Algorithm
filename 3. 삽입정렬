def insertion_sort(arr):
    n = len(arr)
    
    # 1번째 인덱스부터 끝까지 순회 (0번째 인덱스는 이미 정렬되었다고 가정)
    for i in range(1, n):
        key = arr[i]  # 현재 삽입할 기준 위치의 숫자
        j = i - 1
        
        # 기준 숫자(key)보다 큰 원소들을 오른쪽으로 한 칸씩 밀어냄
        while j >= 0 and arr[j] > key:
            arr[j + 1] = arr[j]
            j -= 1
            
        # 빈자리에 기준 숫자(key)를 삽입
        arr[j + 1] = key
        
        # 각 단계별 진행 상황 출력
        print(f"{i}단계 진행 후: {arr}")
        
    return arr

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 삽입 정렬 실행
        sorted_data = insertion_sort(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
