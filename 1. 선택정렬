def selection_sort(arr):
    n = len(arr)
    
    # 배열의 모든 요소를 순회
    for i in range(n):
        # 정렬되지 않은 부분에서 최솟값의 인덱스를 찾음
        min_idx = i
        for j in range(i + 1, n):
            if arr[min_idx] > arr[j]:
                min_idx = j
                
        # 찾은 최솟값을 정렬되지 않은 부분의 맨 앞 요소와 교환
        arr[i], arr[min_idx] = arr[min_idx], arr[i]
        
        # 각 단계별 진행 상황 출력
        print(f"{i + 1}단계 진행 후: {arr}")
        
    return arr

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    # 입력값이 비어있지 않은 경우 리스트로 변환
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 선택 정렬 실행
        sorted_data = selection_sort(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
