def heapify(arr, n, i):
    # 가장 큰 값을 가진 노드의 인덱스를 찾기 위한 함수
    largest = i          # 부모 노드 (초기값)
    left = 2 * i + 1     # 왼쪽 자식 노드
    right = 2 * i + 2    # 오른쪽 자식 노드

    # 왼쪽 자식이 배열 범위 내에 있고, 부모보다 크면 largest 갱신
    if left < n and arr[left] > arr[largest]:
        largest = left

    # 오른쪽 자식이 배열 범위 내에 있고, 현재 largest보다 크면 갱신
    if right < n and arr[right] > arr[largest]:
        largest = right

    # 부모 노드가 가장 큰 값이 아니라면 자식과 자리 교환 후, 계속해서 아래로 힙 정렬(재귀)
    if largest != i:
        arr[i], arr[largest] = arr[largest], arr[i]
        heapify(arr, n, largest)

def heap_sort(arr):
    n = len(arr)

    # 1. 배열을 최대 힙(Max Heap) 구조로 변환
    # 배열의 중간부터 인덱스 0까지 역순으로 확인하며 힙 구조를 만듦
    for i in range(n // 2 - 1, -1, -1):
        heapify(arr, n, i)
        
    print(f"최초 최대 힙 구성 완료: {arr}")

    # 2. 가장 큰 값(루트 노드)을 배열 맨 끝으로 보내고, 남은 트리로 다시 힙 구성
    for i in range(n - 1, 0, -1):
        # 현재 가장 큰 값(arr[0])을 아직 정렬되지 않은 부분의 맨 끝(arr[i])과 교환
        arr[i], arr[0] = arr[0], arr[i]
        
        # 맨 끝으로 간 큰 값을 제외하고, 나머지 요소들로 다시 최대 힙을 구성
        heapify(arr, i, 0)
        
        # 각 단계별 진행 상황 출력
        print(f"{n - i}단계 진행 후: {arr}")

    return arr

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 힙 정렬 실행
        sorted_data = heap_sort(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
