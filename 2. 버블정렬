def bubble_sort(arr):
    n = len(arr)
    
    # 전체 회전 횟수는 배열의 길이 - 1
    for i in range(n - 1):
        swapped = False
        
        # 매 회전마다 가장 큰 숫자가 맨 뒤로 가기 때문에, 
        # 뒤에서부터 i개는 비교할 필요가 없음
        for j in range(n - 1 - i):
            # 인접한 두 원소를 비교하여 앞의 숫자가 더 크면 자리 교환
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
                swapped = True
                
        # 각 단계(회전)별 진행 상황 출력
        print(f"{i + 1}단계 진행 후: {arr}")
        
        # 만약 한 번도 자리가 바뀌지 않았다면 이미 정렬이 끝난 상태이므로 종료
        if not swapped:
            print("💡 더 이상 교환이 일어나지 않아 정렬을 조기 종료합니다.")
            break
            
    return arr

# 1. 사용자로부터 숫자 입력받기
user_input = input("정렬할 숫자를 띄어쓰기로 구분하여 입력하세요 (예: 64 25 12 22 11): ")

# 2. 입력받은 문자열을 정수형 리스트로 변환
try:
    if user_input.strip():
        data = list(map(int, user_input.split()))
        
        print("\n" + "="*40)
        print(f"정렬 전 배열: {data}")
        print("="*40 + "\n")
        
        # 3. 버블 정렬 실행
        sorted_data = bubble_sort(data)
        
        print("\n" + "="*40)
        print(f"최종 정렬된 배열: {sorted_data}")
        print("="*40)
    else:
        print("입력값이 없습니다. 다시 실행해 주세요.")
except ValueError:
    print("숫자만 입력해 주세요. (예: 5 2 9 1 5)")
